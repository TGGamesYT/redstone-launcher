{
  "name": "redstone-launcher",
  "productName": "Redstone Launcher",
  "version": "1.13.7",
  "description": "A Minecraft launcher",
  "author": "Redstone Launcher Team",
  "main": "main.js",
  "scripts": {
    "app": "electron .",
    "buildWin": "electron-builder --win --publish=never",
    "buildLinux": "electron-builder --linux AppImage deb --publish=never",
    "buildMac": "electron-builder --mac --publish=never"
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "npm-check-updates": "^19.6.3"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "discord-rpc": "^4.0.1",
    "electron-store": "^11.0.2",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^5.0.5",
    "prismarine-nbt": "^2.8.0",
    "sharp": "^0.34.5",
    "ssim.js": "^3.5.0",
    "tar-fs": "^3.1.2",
    "tomate-loaders": "^2.0.2",
    "unzipper": "^0.12.3",
    "xml2js": "^0.6.2"
  },
  "build": {
    "appId": "com.redstone-launcher.app",
    "productName": "Redstone Launcher",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "frontend/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "frontend/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "frontend/icon.icns"
    },
    "asar": true
  },
  "overrides": {
    "request": "npm:@cypress/request@^3.0.10",
    "yauzl": "^3.2.1",
    "punycode": "npm:punycode@^2.3.1"
  },
  "type": "module"
}